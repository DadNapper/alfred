# Ignore everything under ~/.hermes by default
*

# Allow traversal into directories
!*/

# Keep git metadata
!.gitignore

# Keep top-level docs and routing config (VPS backup repo tracks these)
!SOUL.md
!identity.md
!config.yaml
!model_routing.yml

# Infrastructure dirs — root .gitignore re-ignores generated content inside them
!hooks/
!hooks/**
!cron/
!cron/**
cron/output/**
!scripts/
!scripts/**
!integrations/
!integrations/**
!config/
!config/**

# Skills tree is governed by skills/.gitignore (roblox-development only)
