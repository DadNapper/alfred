# =====================================
# Default: Ignore Everything
# =====================================

*

# =====================================
# Repository Files
# =====================================

!.gitignore
!README.md

# =====================================
# Hermes Configuration
# =====================================

!.hermes/

# Core docs
!.hermes/identity.md
!.hermes/SOUL.md

# Routing
!.hermes/model_routing.yml
!.hermes/config.yaml

# Skills
!.hermes/skills/
!.hermes/skills/**

# Custom scripts
!.hermes/scripts/
!.hermes/scripts/**

# Hooks
!.hermes/hooks/
!.hermes/hooks/**

# Integrations
!.hermes/integrations/
!.hermes/integrations/**

# Cron definitions
!.hermes/cron/
!.hermes/cron/**

# Config directory
!.hermes/config/
!.hermes/config/**

# =====================================
# Ignore Generated Hermes Content
# =====================================

.hermes/artifacts/
.hermes/audio_cache/
.hermes/cache/
.hermes/image_cache/
.hermes/hermes-agent/
.hermes/logs/
.hermes/lsp/
.hermes/memories/
.hermes/pairing/
.hermes/pastes/
.hermes/sandboxes/
.hermes/sessions/
.hermes/state/
.hermes/state-snapshots/*
.hermes/tmp/
.hermes/cron/output/

# =====================================
# Ignore Hermes Runtime Files
# =====================================

.hermes/*.db
.hermes/*.db-*
.hermes/*.lock
.hermes/*.pid

.hermes/auth.json
.hermes/gateway_state.json
.hermes/models_dev_cache.json
.hermes/provider_models_cache.json
.hermes/ollama_cloud_models_cache.json
.hermes/context_length_cache.yaml

# =====================================
# Secrets
# =====================================

secrets/
.env
.env.*
*.pem
*.key
*.crt

# =====================================
# SSH
# =====================================

.ssh/

# =====================================
# Project Repositories
# =====================================

projects/

# =====================================
# Cursor
# =====================================

.cursor-server/

# =====================================
# Python
# =====================================

__pycache__/
*.pyc
*.pyo
.venv/
.venvs/

# =====================================
# Node
# =====================================

node_modules/
.npm/

# =====================================
# Rust
# =====================================

.cargo/
.rustup/

# =====================================
# Shell History
# =====================================

.bash_history
.zsh_history
.viminfo

# =====================================
# Maintenance
# =====================================

!maintenance/

# Scripts
!maintenance/scripts/
!maintenance/scripts/**

# PM2
!maintenance/pm2/
!maintenance/pm2/**

# Ignore generated outputs
maintenance/backups/
maintenance/logs/

# =====================================
# Archives / Logs
# =====================================

*.log
*.tar.gz

# =====================================
# Linux User Noise
# =====================================

.zcompdump*
.sudo_as_admin_successful

.hermes/cron/ticker_heartbeat
.hermes/cron/ticker_last_success
